{
  "name": "llm-inspector",
  "version": "0.1.0",
  "description": "Capture and analyze LLM API request payloads — understand token usage for Claude Code, OpenAI, and other LLM tools",
  "type": "module",
  "bin": {
    "llm-inspector": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "start": "node dist/cli.js start",
    "stop": "node dist/cli.js stop",
    "analyze": "node dist/cli.js analyze",
    "dev": "tsup src/cli.ts --format esm --watch"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jleechanorg/llm_inspector.git"
  },
  "keywords": [
    "llm",
    "token",
    "inspector",
    "claude",
    "openai",
    "anthropic",
    "context",
    "proxy"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
